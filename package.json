{
  "name": "skate-kbm",
  "version": "0.1.4",
  "description": "Plain Node CLI keyboard and mouse to virtual Xbox 360 controller mapper for Windows games.",
  "type": "module",
  "bin": {
    "skate-kbm": "bin/skate-kbm.js"
  },
  "files": [
    "bin/skate-kbm.js",
    "dist/app/mapper/skate-kbm-mapper.exe",
    "scripts/install-vigembus.ps1",
    "README.md",
    "LICENSE"
  ],
  "os": [
    "win32"
  ],
  "cpu": [
    "x64"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasperdevs/skate-kbm.git"
  },
  "bugs": {
    "url": "https://github.com/jasperdevs/skate-kbm/issues"
  },
  "homepage": "https://github.com/jasperdevs/skate-kbm#readme",
  "keywords": [
    "keyboard",
    "mouse",
    "controller",
    "xbox",
    "vigembus",
    "node",
    "windows"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:mapper",
    "build:mapper": "cargo build --release && powershell -NoProfile -ExecutionPolicy Bypass -Command \"New-Item -ItemType Directory -Force ./dist/app/mapper | Out-Null; Copy-Item ./target/release/skate-kbm-mapper.exe ./dist/app/mapper/skate-kbm-mapper.exe -Force\"",
    "driver": "powershell -ExecutionPolicy Bypass -File ./scripts/install-vigembus.ps1",
    "dev": "node ./bin/skate-kbm.js",
    "start": "node ./bin/skate-kbm.js",
    "check": "cargo check"
  }
}
