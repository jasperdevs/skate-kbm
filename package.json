{
  "name": "skate-kbm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "skate-kbm": "./src/cli/index.ts"
  },
  "scripts": {
    "build": "bun run build:mapper && bun run build:cli",
    "build:mapper": "dotnet publish ./src/SkateKbm.Mapper/SkateKbm.Mapper.csproj -c Release -r win-x64 --self-contained true -p:PublishSingleFile=true -p:EnableCompressionInSingleFile=true -o ./dist/app/mapper",
    "build:cli": "bun build --compile --target=bun --outfile ./dist/app/skate-kbm.exe ./src/cli/index.ts",
    "driver": "powershell -ExecutionPolicy Bypass -File ./scripts/install-vigembus.ps1",
    "dev": "bun ./src/cli/index.ts",
    "start": "bun ./src/cli/index.ts",
    "check": "dotnet build ./src/SkateKbm.Mapper/SkateKbm.Mapper.csproj -c Release"
  },
  "dependencies": {
    "@opentui/core": "^0.1.100"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3"
  }
}
